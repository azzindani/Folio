{
  "name": "folio",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Local-first graphic design engine with YAML payloads",
  "bin": {
    "folio-mcp": "./dist/mcp-server.js"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:analyze": "ANALYZE=true vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts --max-warnings 0",
    "lint:fix": "eslint src --ext .ts --fix",
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:unit:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:e2e": "playwright test tests/e2e/ --project=chromium",
    "test:visual": "playwright test tests/visual/ --project=chromium",
    "test:update-snapshots": "playwright test --update-snapshots --project=chromium",
    "test:bench": "vitest bench",
    "mcp": "node --loader ts-node/esm src/mcp/server.ts",
    "mcp:http": "node --loader ts-node/esm src/mcp/http-server.ts",
    "clean": "rm -rf dist node_modules .vite"
  },
  "repository": {
    "type": "git",
    "url": "http://local_proxy@127.0.0.1:38141/git/azzindani/Folio"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@playwright/test": "1.59.1",
    "@types/js-yaml": "^4.0.9",
    "@types/katex": "^0.16.8",
    "@types/node": "^25.6.0",
    "@types/prismjs": "^1.26.6",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "@vitest/coverage-v8": "^4.1.5",
    "esbuild": "^0.28.0",
    "eslint": "^10.2.1",
    "jsdom": "^29.0.2",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "@floating-ui/dom": "^1.7.6",
    "imagetracerjs": "^1.2.6",
    "interactjs": "^1.10.27",
    "js-yaml": "^4.1.1",
    "jspdf": "^4.2.1",
    "katex": "^0.16.45",
    "marked": "^18.0.2",
    "mermaid": "^11.14.0",
    "monaco-editor": "^0.55.1",
    "prismjs": "^1.30.0",
    "vega-embed": "^7.1.0"
  },
  "overrides": {
    "vega-lite": "^6.4.3",
    "vega": "^6.2.0"
  }
}
