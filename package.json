{
  "name": "folio",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Local-first graphic design engine with YAML payloads",
  "bin": {
    "folio-mcp": "./dist/mcp-server.js"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:analyze": "ANALYZE=true vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts --max-warnings 0",
    "lint:fix": "eslint src --ext .ts --fix",
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:unit:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:e2e": "playwright test tests/e2e/ --project=chromium",
    "test:visual": "playwright test tests/visual/ --project=chromium",
    "test:update-snapshots": "playwright test --update-snapshots --project=chromium",
    "test:bench": "vitest bench",
    "mcp": "node --loader ts-node/esm src/mcp/server.ts",
    "mcp:http": "node --loader ts-node/esm src/mcp/http-server.ts",
    "clean": "rm -rf dist node_modules .vite"
  },
  "repository": {
    "type": "git",
    "url": "http://local_proxy@127.0.0.1:38141/git/azzindani/Folio"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@playwright/test": "1.56.1",
    "@types/js-yaml": "^4.0.9",
    "@types/katex": "^0.16.7",
    "@types/node": "^25.5.2",
    "@types/prismjs": "^1.26.5",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "@vitest/coverage-v8": "^4.1.3",
    "esbuild": "^0.28.0",
    "eslint": "^10.2.0",
    "jsdom": "^29.0.2",
    "typescript": "^6.0.2",
    "vite": "^8.0.7",
    "vitest": "^4.1.3"
  },
  "dependencies": {
    "@floating-ui/dom": "^1.7.6",
    "imagetracerjs": "^1.2.6",
    "interactjs": "^1.10.27",
    "js-yaml": "^4.1.1",
    "jspdf": "^2.5.2",
    "katex": "^0.16.11",
    "marked": "^18.0.0",
    "mermaid": "^11.4.1",
    "monaco-editor": "^0.55.1",
    "prismjs": "^1.29.0",
    "vega-embed": "^6.26.0"
  },
  "overrides": {
    "vega-lite": "^5.20.1",
    "vega": "^5.30.0"
  }
}
